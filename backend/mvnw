#!/bin/sh
# Maven Wrapper script - downloads maven if not present
# Simplified version for Docker builds

set -e

MAVEN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-3.8.6"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.8.6/apache-maven-3.8.6-bin.tar.gz"

if [ ! -d "${MAVEN_HOME}" ]; then
    echo "Downloading Maven 3.8.6..."
    mkdir -p "${MAVEN_HOME}"
    curl -fsSL "${MAVEN_URL}" | tar xz -C "${MAVEN_HOME}" --strip-components=1
fi

exec "${MAVEN_HOME}/bin/mvn" "$@"
