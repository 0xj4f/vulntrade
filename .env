# VulnTrade Environment Configuration
# VULN: All secrets in plaintext in .env file

# Database
POSTGRES_DB=vulntrade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Redis (no auth - intentional)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (weak secret - intentional)
JWT_SECRET=vulntrade-secret
JWT_EXPIRATION=86400000

# Backend
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
DEBUG_PORT=5005

# Admin credentials (weak - intentional)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_API_KEY=vt-api-key-12345-not-so-secret

# Flags (CTF)
FLAG_1=FLAG{4ctu4t0r_3xp0s3d_s3cr3ts}
FLAG_2=FLAG{1d0r_4dm1n_pr0f1l3_n0t3s}
FLAG_3=FLAG{r3d1s_n0_4uth_p1v0t}
FLAG_4=FLAG{sql1_h1dd3n_t4bl3_fl4g}
FLAG_5=FLAG{rc3_f1l3syst3m_4cc3ss}
FLAG_6=FLAG{h0r1z0nt4l_pr1v3sc_p0rtf0l10}
FLAG_7=FLAG{st0mp_4dm1n_ch4nn3l_l34k}
FLAG_8=FLAG{h34pdump_m3m0ry_s3cr3ts}
FLAG_9=FLAG{h2_c0ns0l3_d4t4b4s3_4cc3ss}
FLAG_10=FLAG{jwt_f0rg3d_4dm1n_m4st3r}

# Frontend
REACT_APP_API_URL=http://localhost:8085
REACT_APP_WS_URL=ws://localhost:8085/ws

# Log shipper (Fluent Bit → S3)
# Leave blank to start log-shipper without shipping (will fail auth cleanly).
# Fill in real values to enable S3 uploads every 1 minute.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-west-2
S3_BUCKET=wazuh-application-logs
